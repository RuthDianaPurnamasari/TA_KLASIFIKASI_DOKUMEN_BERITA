{
    "framework": "TensorFlow/Keras",
    "tensorflow_version": "2.20.0",
    "random_seed": 42,
    "num_classes": 4,
    "epochs_maximum": 20,
    "batch_size": 64,
    "learning_rate": 0.001,
    "optimizer": "Adam",
    "loss": "sparse_categorical_crossentropy",
    "training_metric": "accuracy",
    "model_selection_metric": "val_loss",
    "model_selection_mode": "min",
    "test_set_used_during_training": false,
    "k4_used": false,
    "total_models": 2,
    "total_scenarios": 5,
    "total_experiments": 10,
    "shared_architecture": {
        "embedding_dim": 128,
        "dense_units": 128,
        "spatial_dropout_rate": 0.2,
        "dropout_rate": 0.5
    },
    "cnn": {
        "num_filters": 128,
        "kernel_size": 5,
        "padding_handling": "Padding embedding dibuat nol dan full-padding convolution windows diabaikan dalam global max pooling."
    },
    "attention_bilstm": {
        "lstm_units_per_direction": 64,
        "bilstm_output_units": 128,
        "attention_units": 64,
        "recurrent_dropout_rate": 0.0,
        "padding_handling": "Embedding mask_zero=True dan mask diteruskan ke BiLSTM serta attention."
    },
    "callbacks": {
        "terminate_on_nan": true,
        "early_stopping": {
            "monitor": "val_loss",
            "patience": 5,
            "min_delta": 0.0001,
            "mode": "min",
            "restore_best_weights": true
        },
        "reduce_lr_on_plateau": {
            "monitor": "val_loss",
            "factor": 0.5,
            "patience": 2,
            "min_delta": 0.0001,
            "minimum_learning_rate": 1e-06,
            "mode": "min"
        },
        "model_checkpoint": {
            "monitor": "val_loss",
            "mode": "min",
            "save_best_only": true,
            "save_weights_only": false
        },
        "csv_logger": {
            "append": false
        }
    },
